#
# !! Use at your own risk !!
#
# Visualize budgeted versus actual fxrates for select currencies
#
# https://github.com/fawazahmed0/exchange-api
# https://cdn.jsdelivr.net/npm/@fawazahmed0/currency-api@latest/v1/currencies.json

# run this daily, like from cron
fxrates-from-adhoc.sh

# run this to update data for a specific date
fxrates-from-recovery.sh

# run this to fill in missing data from a specific date
fxrates-from-date.sh

# example
INR2USD.png

# example sqlite3 output
2026-06-01  eur       1.16473
2026-06-01  ils       0.35626
2026-06-01  inr       0.01054
2026-06-01  rsd       0.00993
2026-06-01  twd       0.03189
2026-06-02  eur       1.16371
2026-06-02  ils       0.35444
2026-06-02  inr       0.01051
2026-06-02  rsd       0.00991
2026-06-02  twd       0.03179

#
# misc sqlite3 stuff
#

sudo apt-get install sqlite3 sqlite3-tools

cat << EOF > fxrates-schema.sql
CREATE TABLE IF NOT EXISTS exchange_rates (
  date TEXT NOT NULL,
  currency TEXT NOT NULL,
  rate REAL NOT NULL,
  PRIMARY KEY (date, currency)
);
EOF

sqlite3 fxrates.db < fxrates-schema.sql

sqlite3 fxrates.db "SELECT currency, rate FROM exchange_rates WHERE date = '2025-07-28';"
sqlite3 fxrates.db "SELECT rate FROM exchange_rates WHERE date = '2025-07-28' AND currency = 'inr';"
sqlite3 fxrates.db "SELECT * FROM exchange_rates;"
sqlite3 fxrates.db "SELECT DISTINCT currency FROM exchange_rates;"

sqlite3 fxrates.db <<EOF
.headers on
.mode column
SELECT * FROM exchange_rates WHERE date = '2025-07-28';
EOF
 
sqlite3 fxrates.db <<EOF
.headers on
.mode column
SELECT date FROM exchange_rates GROUP BY date ORDER BY date DESC LIMIT 10;
EOF

sqlite3 fxrates.db <<EOF
.headers on
.mode column
SELECT * FROM exchange_rates ORDER BY date DESC LIMIT 10;
EOF

